[rke2_servers]
mgmt-cp-1 ansible_host=192.168.1.101
mgmt-cp-2 ansible_host=192.168.1.102
mgmt-cp-3 ansible_host=192.168.1.103

[rke2_first_server]
mgmt-cp-1 ansible_host=192.168.1.101

[rke2_servers:vars]
ansible_user=ubuntu
ansible_ssh_private_key_file=~/.ssh/id_ed25519

# RKE2 cluster join token — must match terraform.tfvars rke2_token
rke2_token=your-very-long-random-token-here

# rke2_server_url: mgmt-cp-2 and mgmt-cp-3 join via this address.
# IMPORTANT: use mgmt-cp-1's direct IP for initial bootstrap,
# NOT the VIP — kube-vip doesn't exist yet during first run.
# After cluster is stable and kube-vip is running, you can change
# this to the VIP for future re-runs.
rke2_server_url=192.168.1.101

# VIP written into the TLS SAN — must match mgmt_vip in terraform.tfvars
rke2_vip=192.168.1.100

rke2_extra_sans=[]
rke2_node_role=control-plane
rke2_node_taints=["CriticalAddonsOnly=true:NoSchedule"]
